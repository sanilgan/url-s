PORT=3005
NODE_ENV=development
BASE_URL=http://localhost:3005
JWT_SECRET=replace-with-a-long-random-secret

# Firebase project
FIREBASE_PROJECT_ID=url-s-c6e4d

# Recommended for Vercel: paste the complete service-account JSON on one line.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"url-s-c6e4d","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-...@url-s-c6e4d.iam.gserviceaccount.com","client_id":"..."}

# Alternative to FIREBASE_SERVICE_ACCOUNT_KEY:
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@url-s-c6e4d.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional local emulator:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
