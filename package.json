{
  "name": "url-shortener",
  "version": "1.0.0",
  "description": "Firebase Firestore tabanlı URL kısaltıcı uygulaması",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "check-firebase": "ts-node src/scripts/initDb.ts",
    "init-db": "npm run check-firebase"
  },
  "engines": {
    "node": "22.x"
  },
  "keywords": [
    "url-shortener",
    "nodejs",
    "firebase",
    "firestore",
    "typescript"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^3.3.6",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.0",
    "@types/validator": "^13.11.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
